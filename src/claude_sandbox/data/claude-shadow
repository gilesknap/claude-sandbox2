#!/usr/bin/env bash
# Shadow `claude` binary. Wraps the real Claude in a bwrap sandbox so
# that `claude` on the user's $PATH always runs sandboxed.
#
# The three template defaults below (@@REAL_CLAUDE@@, @@SRC_DIR@@,
# @@GITCONFIG_PATH@@) are substituted by the installer at install time.
# Setting the corresponding CLAUDE_SANDBOX_* env vars at runtime still
# overrides.
#
# Recursion guard: if IS_SANDBOX=1 is already set we are inside the
# sandbox (e.g. a hook or skill spawned `claude`), so fall through to
# the real binary directly. Internal claude-spawns-claude does not
# double-wrap.

set -euo pipefail

REAL_CLAUDE="${CLAUDE_SANDBOX_REAL_CLAUDE:-@@REAL_CLAUDE@@}"

if [ "${IS_SANDBOX:-}" = "1" ]; then
    exec "$REAL_CLAUDE" "$@"
fi

export CLAUDE_SANDBOX_GITCONFIG_PATH="${CLAUDE_SANDBOX_GITCONFIG_PATH:-@@GITCONFIG_PATH@@}"

SRC_DIR="${CLAUDE_SANDBOX_SRC_DIR:-@@SRC_DIR@@}"

# Loud-fail when the install-time-baked paths are missing. Without
# these checks the shadow falls into one of two confusing modes:
#   - SRC_DIR gone: `source $SRC_DIR/.../bwrap_argv.sh` silently fails
#     and `bwrap_argv_build` is undefined a few lines down.
#   - REAL_CLAUDE gone: bwrap launches but the exec'd path doesn't
#     exist inside the sandbox, so claude exits immediately with a
#     hard-to-read errno.
# Failing here points the user at the real cause: the clone the shadow
# was wired up against has moved or been deleted, and `./install` needs
# re-running from a fresh clone.
if [ ! -d "$SRC_DIR" ]; then
    echo "claude-sandbox: source tree missing at $SRC_DIR (recorded at install time)." >&2
    echo "  Re-run \`./install\` from a fresh clone of claude-sandbox2." >&2
    exit 1
fi
if [ ! -x "$REAL_CLAUDE" ]; then
    echo "claude-sandbox: real Claude binary missing at $REAL_CLAUDE." >&2
    echo "  Re-run \`./install\` from the clone to re-place it." >&2
    exit 1
fi

# Probe whether bwrap's --proc /proc actually mounts a procfs that
# reflects the new pidns. On rootless nested userns hosts (typical
# devcontainers) the mount succeeds but the procfs binds to bwrap's
# outer pidns, so host PIDs leak into the sandbox's /proc even though
# --unshare-pid creates a real pidns at the kernel level. The earlier
# probe just ran /bin/true and called success — useless for catching
# this. The new probe is deterministic: inside the bwrap sandbox $$
# (kernel-cached pidns-aware PID) must equal /proc/self/status:Pid:
# (procfs's view of self). They agree iff procfs is bound to our
# pidns. Override on the parent shell with CLAUDE_SANDBOX_FRESH_PROC=0/1
# to skip the probe (useful for tests, or for users who already know
# the answer for their host). ~15 ms on warm cache.
#
# When the probe fails, the argv switches to --ro-bind /proc /proc.
# /proc still reflects the host's view, but credential-bearing procfs
# entries (environ, maps, fd, mem) stay gated by YAMA ptrace_scope=1
# so this is information-disclosure, not credential exfil. See
# README-CLAUDE.md for the full tally.
if [ -z "${CLAUDE_SANDBOX_FRESH_PROC:-}" ]; then
    if bwrap --ro-bind / / --unshare-user-try --unshare-pid --proc /proc \
            --dev-bind /dev /dev \
            -- /bin/sh -c \
            'test "$$" = "$(awk "/^Pid:/{print \$2;exit}" /proc/self/status)"' \
            >/dev/null 2>&1; then
        export CLAUDE_SANDBOX_FRESH_PROC=1
    else
        export CLAUDE_SANDBOX_FRESH_PROC=0
        echo "claude-sandbox: notice — procfs view will leak host PIDs " \
             "(bwrap --proc /proc cannot bind procfs to the new pidns on " \
             "this rootless host). Kernel-level pidns isolation (kill / " \
             "ptrace scoping) is intact; YAMA ptrace_scope continues to " \
             "block credential-bearing procfs entries. See README-CLAUDE.md." >&2
    fi
fi

# Ensure the credential dirs the bwrap argv builder selectively re-binds
# (gh, glab) exist before launch. Without this, `gh auth login` run from
# inside the sandbox before a token is provisioned writes into the
# in-sandbox tmpfs and the credential vanishes when bwrap exits. mkdir
# is sub-ms and idempotent; the dirs persist in the container fs.
mkdir -p "${HOME:-/root}/.config/gh" "${HOME:-/root}/.config/glab-cli"

# Refresh /etc/claude-gitconfig from the current host git identity on
# every launch. Late-bind by design: at postCreate time (when
# `bash install` ran gitconfig.generate) VS Code's
# dev.containers.copyGitConfig may not yet have populated
# /root/.gitconfig, so the curated config can end up with empty
# user.name / user.email and Claude's commits land unattributed. By
# the time the user types `claude`, copyGitConfig has long since
# fired — re-render here so the [user] block always reflects the host
# identity copyGitConfig copied in. ~5 ms; under the 50 ms launch
# budget.
#
# Template MUST MATCH src/claude_sandbox/gitconfig.py::render. If you
# change one, change the other (and tests/test_gitconfig.py).
git_name=$(git config --get user.name 2>/dev/null || true)
git_email=$(git config --get user.email 2>/dev/null || true)
cat > "$CLAUDE_SANDBOX_GITCONFIG_PATH" <<EOF
[user]
    name = $git_name
    email = $git_email
[credential "https://github.com"]
    helper = !gh auth git-credential
[init]
    defaultBranch = main
[safe]
    directory = *
EOF

# Same reasoning for ~/.claude.json: Claude Code writes its OAuth token
# and recent-projects state into a top-level *file* (not under the
# bound ~/.claude/ directory). Pre-creating it lets the argv builder's
# `--bind` succeed on the very first launch — without this the
# strict-under-/root tmpfs swallows the auth and the user re-logs in
# on every invocation. `touch` on an existing file is a no-op apart
# from mtime.
touch "${HOME:-/root}/.claude.json"

# shellcheck source=bwrap_argv.sh
source "$SRC_DIR/src/claude_sandbox/data/bwrap_argv.sh"

mapfile -t ARGV < <(bwrap_argv_build "$PWD" "$REAL_CLAUDE" "$@")
exec "${ARGV[@]}"
