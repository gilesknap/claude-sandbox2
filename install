#!/usr/bin/env bash
# claude-sandbox installer entry point. Pipe-ready:
#   curl -fsSL https://raw.githubusercontent.com/gilesknap/claude-sandbox2/main/install | bash
#
# This script is a thin probe-and-bootstrap shim. It establishes the
# preconditions that the Python orchestrator (src/claude_sandbox/cli.py)
# cannot establish for itself — git, the source clone, and uv — and
# then re-execs into the orchestrator. Everything substantive happens
# Python-side.

set -euo pipefail

SRC_REPO="${CLAUDE_SANDBOX_REPO:-https://github.com/gilesknap/claude-sandbox2.git}"
SRC_REF="${CLAUDE_SANDBOX_REF:-main}"
SRC_DIR="${CLAUDE_SANDBOX_SRC_DIR:-/opt/claude-sandbox-src}"

# v1 targets root-in-devcontainer; refuse cleanly on non-root rather
# than producing a confusing apt-get permission failure.
if [ "$(id -u)" -ne 0 ]; then
    echo "claude-sandbox: refusing — v1 requires running as root inside a devcontainer (rootless podman + remoteUser=root). Non-root host install is tracked as a v2 follow-up." >&2
    exit 1
fi

if ! command -v apt-get >/dev/null 2>&1; then
    echo "claude-sandbox: refusing — claude-sandbox v1 supports Debian/Ubuntu only (no apt-get on PATH). File an issue at gilesknap/claude-sandbox2 to request your distro." >&2
    exit 1
fi

export DEBIAN_FRONTEND=noninteractive
apt-get update -qq
# Bootstrap minimum for the clone + curl-installs; the orchestrator's
# probe re-asserts everything before mutating workspace state.
apt-get install -y -qq --no-install-recommends \
    bubblewrap nodejs gh ca-certificates curl jq git glab

# Install uv if absent. uv hosts the project venv at $SRC_DIR/.venv and
# runs the typer CLI; depending on the system Python's pip/venv would
# tie us to whatever Python the base image ships.
if ! command -v uv >/dev/null 2>&1; then
    curl -fsSL https://astral.sh/uv/install.sh | sh
    # uv installer drops the binary at ~/.local/bin/uv; make it visible
    # to the rest of this script.
    export PATH="$HOME/.local/bin:$PATH"
fi

# Real Claude binary. Anthropic's installer drops it at ~/.local/bin/claude;
# the orchestrator moves it to /opt/claude/bin/claude so the shadow on
# $PATH always wins. Also check ~/.local/bin/claude: a prior install that
# ran the curl-bash but failed before the orchestrator moved the binary
# leaves it there, and re-running curl-bash on every retry is slow.
if [ ! -x /opt/claude/bin/claude ] \
    && [ ! -x "${HOME}/.local/bin/claude" ] \
    && ! command -v claude >/dev/null 2>&1; then
    curl -fsSL https://claude.ai/install.sh | bash
fi

# When `install` is invoked from a checkout of the source tree (the
# dogfooding loop: edit Python, re-run `./install`), skip the clone and
# use the checkout in place. Without this the orchestrator always runs
# against the cloned `main`, so local fixes to probe.py / installer.py
# don't take effect until they're pushed and merged.
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
if [ -z "${CLAUDE_SANDBOX_SRC_DIR:-}" ] \
    && [ -f "$SCRIPT_DIR/pyproject.toml" ] \
    && [ -d "$SCRIPT_DIR/src/claude_sandbox" ] \
    && [ -d "$SCRIPT_DIR/.git" ]; then
    SRC_DIR="$SCRIPT_DIR"
    echo "claude-sandbox: using local checkout at $SRC_DIR (skipping clone)"
else
    install -d "$(dirname "$SRC_DIR")"
    if [ -d "$SRC_DIR/.git" ]; then
        git -C "$SRC_DIR" fetch --quiet origin "$SRC_REF"
        git -C "$SRC_DIR" checkout --quiet "$SRC_REF"
        git -C "$SRC_DIR" reset --hard --quiet "origin/$SRC_REF"
    else
        rm -rf "$SRC_DIR"
        git clone --quiet --branch "$SRC_REF" "$SRC_REPO" "$SRC_DIR"
    fi
fi

cd "$SRC_DIR"
uv sync --quiet
exec uv run claude-sandbox install "$@"
