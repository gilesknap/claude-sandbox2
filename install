#!/usr/bin/env bash
# claude-sandbox installer shim. Resolves its own dir and execs the
# real installer under .devcontainer/claude-sandbox/.
#
#   git clone https://github.com/gilesknap/claude-sandbox2.git
#   cd claude-sandbox2
#   sudo ./install

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

if [ "$(id -u)" -ne 0 ] && [ "${CLAUDE_SANDBOX_SMOKE:-0}" != "1" ]; then
    echo "claude-sandbox: refusing — run as root (apt-get install needs it)." >&2
    echo "  sudo ./install" >&2
    exit 1
fi

exec bash "$SCRIPT_DIR/.devcontainer/claude-sandbox/install.sh" "$@"
