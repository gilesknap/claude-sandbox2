#!/usr/bin/env bash
# claude-sandbox installer entry point. Must be run from a git clone of
# the project:
#
#   git clone https://github.com/gilesknap/claude-sandbox2.git
#   cd claude-sandbox2
#   sudo ./install
#
# No curl-pipe install path: we deliberately want the source tree the
# user is sitting in to BE the source tree the shadow points at on every
# launch. That means edits to .claude/, bwrap_argv.sh, or the Python
# orchestrator take effect immediately on the next `claude` run with
# nothing to re-sync.
#
# This script is a thin probe-and-bootstrap shim. It establishes the
# preconditions that the Python orchestrator (src/claude_sandbox/cli.py)
# cannot establish for itself — apt deps, the real Claude binary, and
# uv — and then re-execs into the orchestrator pointed at $SCRIPT_DIR.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Refuse if not executed from a recognisable claude-sandbox clone. This
# also catches the legacy `curl … | bash` invocation pattern: piping
# leaves $SCRIPT_DIR pointing at /dev/fd/<n> or a tempdir without a
# pyproject.toml, so the check fails fast with an actionable error.
if [ ! -f "$SCRIPT_DIR/pyproject.toml" ] \
    || [ ! -d "$SCRIPT_DIR/src/claude_sandbox" ]; then
    cat >&2 <<EOF
claude-sandbox: refusing — \`install\` must be run from a clone of the
claude-sandbox2 repository.

    git clone https://github.com/gilesknap/claude-sandbox2.git
    cd claude-sandbox2
    sudo ./install

(The curl-pipe install path was removed; the shadow now points at this
clone in place, so the clone must exist on disk and stay there.)
EOF
    exit 1
fi

# v1 targets root-in-devcontainer; refuse cleanly on non-root rather
# than producing a confusing apt-get permission failure.
if [ "$(id -u)" -ne 0 ]; then
    echo "claude-sandbox: refusing — v1 requires running as root inside a devcontainer (rootless podman + remoteUser=root). Non-root host install is tracked as a v2 follow-up." >&2
    exit 1
fi

if ! command -v apt-get >/dev/null 2>&1; then
    echo "claude-sandbox: refusing — claude-sandbox v1 supports Debian/Ubuntu only (no apt-get on PATH). File an issue at gilesknap/claude-sandbox2 to request your distro." >&2
    exit 1
fi

export DEBIAN_FRONTEND=noninteractive
apt-get update -qq
# Bootstrap minimum for the curl-installs below; the orchestrator's
# probe re-asserts everything before mutating workspace state.
apt-get install -y -qq --no-install-recommends \
    bubblewrap nodejs gh ca-certificates curl jq git glab

# Install uv if absent. uv hosts the project venv at $SCRIPT_DIR/.venv
# and runs the typer CLI; depending on the system Python's pip/venv
# would tie us to whatever Python the base image ships.
if ! command -v uv >/dev/null 2>&1; then
    curl -fsSL https://astral.sh/uv/install.sh | sh
    # uv installer drops the binary at ~/.local/bin/uv; make it visible
    # to the rest of this script.
    export PATH="$HOME/.local/bin:$PATH"
fi

# Real Claude binary. Anthropic's installer drops it at ~/.local/bin/claude
# (symlink into ~/.local/share/claude/versions/). The orchestrator copies
# the resolved file into <clone>/.runtime/claude (gitignored). Skip the
# Anthropic install if either copy is already present:
#   - <clone>/.runtime/claude — orchestrator-managed final destination.
#   - ~/.local/bin/claude — Anthropic's drop, present after a prior
#     curl-bash that crashed before the orchestrator's copy step.
# Avoids re-downloading 200+ MB on every retry / rebuild.
if [ ! -x "$SCRIPT_DIR/.runtime/claude" ] \
    && [ ! -e "${HOME}/.local/bin/claude" ] \
    && ! command -v claude >/dev/null 2>&1; then
    curl -fsSL https://claude.ai/install.sh | bash
fi

cd "$SCRIPT_DIR"
uv sync --quiet
export CLAUDE_SANDBOX_SRC_DIR="$SCRIPT_DIR"
exec uv run claude-sandbox install "$@"
